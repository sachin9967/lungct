# Environment Configuration Example
# Copy this to .env and update values as needed

# ======================
# Application Settings
# ======================
APP_NAME=Lung Oncology AI
APP_VERSION=1.0
APP_ENV=development

# ======================
# Streamlit Settings
# ======================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_SHOWERRORDETAILS=true

# ======================
# Model Settings
# ======================
MODEL_PATH=./models
MAX_MODEL_LOAD_TIME=60

# ======================
# Upload Settings
# ======================
UPLOAD_PATH=./uploads
OUTPUT_PATH=./outputs
MAX_UPLOAD_SIZE_MB=100
ALLOWED_IMAGE_FORMATS=png,jpg,jpeg
ALLOWED_CSV_COLUMNS_MIN=1

# ======================
# Performance Settings
# ======================
PREDICTION_TIMEOUT_SECONDS=30
ENABLE_GPU=false
BATCH_SIZE=1

# ======================
# Logging Settings
# ======================
LOG_LEVEL=INFO
LOG_FILE=app.log
ENABLE_DEBUG_LOGGING=false

# ======================
# Security Settings
# ======================
ENABLE_AUTH=false
ADD_FOOTER=true
ENABLE_SHARING=false

# ======================
# Database (Optional)
# ======================
# DATABASE_URL=sqlite://./predictions.db
# DATABASE_ECHO=false

# ======================
# API Settings (Optional)
# ======================
# FLASK_PORT=5000
# FLASK_ENV=production
# API_TIMEOUT=30
